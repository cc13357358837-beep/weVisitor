.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.header {
  padding: 40rpx;
  background-color: white;
  border-bottom: 1rpx solid #e5e5e5;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.steps {
  display: flex;
  justify-content: space-between;
  padding: 40rpx;
  background-color: white;
  margin: 20rpx 0;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
}

.step-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #e5e5e5;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  z-index: 2;
}

.step-item.active .step-dot {
  background-color: #0055BE;
  color: white;
}

.step-line {
  position: absolute;
  top: 20rpx;
  left: 50%;
  width: 100%;
  height: 2rpx;
  background-color: #e5e5e5;
  z-index: 1;
}

.step-line.active {
  background-color: #0055BE;
}

.step-text {
  font-size: 20rpx;
  color: #999;
  margin-top: 10rpx;
}

.step-item.active .step-text {
  color: #0055BE;
  font-weight: bold;
}

.form {
  flex: 1;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
}

.form-item {
  margin-bottom: 30rpx;
  background-color: white;
  border-radius: 10rpx;
  padding: 0 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
}

.input {
  height: 80rpx;
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.code-btn {
  height: 60rpx;
  width: 200rpx;
  background-color: #0055BE;
  color: white;
  font-size: 24rpx;
  border-radius: 10rpx;
  margin-left: 20rpx;
}

.next-btn, .login-btn {
  height: 100rpx;
  line-height: 100rpx;
  width: 100%;
  border-radius: 60rpx;
  background-color: #0055BE;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 40rpx;
}

.success {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #4CD964;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.success-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.success-subtext {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 60rpx;
}
