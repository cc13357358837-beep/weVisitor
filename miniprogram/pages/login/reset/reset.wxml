<view class="container">
  
  <view class="form">
    <!-- 修改密码表单 -->
    <view class="form-item">
      <input class="input" placeholder="请输入旧密码" bindinput="onInput" data-key="oldPassword" password />
    </view>
    <view class="form-item">
      <input class="input" placeholder="请设置6-20位新密码" bindinput="onInput" data-key="newPassword" password />
    </view>
    <view class="form-item">
      <input class="input" placeholder="请确认新密码" bindinput="onInput" data-key="confirmPassword" password />
    </view>
    <button class="next-btn" bindtap="confirmReset">确定</button>
    
    <!-- 重置成功 -->
    <view wx:if="{{step == 2}}" class="success">
      <view class="success-icon">✓</view>
      <view class="success-text">密码修改成功</view>
      <button class="login-btn" bindtap="goBack">返回</button>
    </view>
  </view>
</view>
