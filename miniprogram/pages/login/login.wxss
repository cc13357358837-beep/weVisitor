.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #0055BE 0%, #007AFF 100%);
  height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-bottom-left-radius: 30rpx;
  border-bottom-right-radius: 30rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.1);
}

.logo {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-icon {
  width: 100rpx;
  height: 100rpx;
  background-color: white;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  font-weight: bold;
  color: #0055BE;
  margin-bottom: 20rpx;
}

.logo-text {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
}

.logo-subtext {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.form {
  flex: 1;
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
}

.form-item {
  margin-bottom: 30rpx;
  background-color: white;
  border-radius: 10rpx;
  padding: 0 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.input {
  height: 80rpx;
  font-size: 28rpx;
  color: #333;
}

.login-btn {
  height: 80rpx;
  background-color: #0055BE;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 10rpx;
  margin-top: 40rpx;
  margin-bottom: 30rpx;
}

.forget-password {
  align-self: flex-end;
  font-size: 24rpx;
  color: #0055BE;
}
