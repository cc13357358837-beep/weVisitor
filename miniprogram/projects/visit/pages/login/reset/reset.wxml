<view class="container">
  <view class="header">
    <text class="title">重置密码</text>
  </view>
  
  <view class="steps">
    <view class="step-item {{step >= 1 ? 'active' : ''}}">
      <view class="step-dot">{{step >= 1 ? '✓' : '1'}}</view>
      <view class="step-line {{step >= 2 ? 'active' : ''}}"></view>
      <view class="step-text">验证身份</view>
    </view>
    <view class="step-item {{step >= 2 ? 'active' : ''}}">
      <view class="step-dot">{{step >= 2 ? '✓' : '2'}}</view>
      <view class="step-line {{step >= 3 ? 'active' : ''}}"></view>
      <view class="step-text">验证密码</view>
    </view>
    <view class="step-item {{step >= 3 ? 'active' : ''}}">
      <view class="step-dot">{{step >= 3 ? '✓' : '3'}}</view>
      <view class="step-line {{step >= 4 ? 'active' : ''}}"></view>
      <view class="step-text">重置成功</view>
    </view>
    <view class="step-item {{step >= 4 ? 'active' : ''}}">
      <view class="step-dot">{{step >= 4 ? '✓' : '4'}}</view>
      <view class="step-text">完成</view>
    </view>
  </view>
  
  <view class="form">
    <!-- 步骤1：输入手机号 -->
    <view wx:if="{{step == 1}}">
      <view class="form-item">
        <input class="input" placeholder="请输入手机号" bindinput="onInput" data-key="mobile" />
      </view>
      <view class="form-item">
        <input class="input" placeholder="请输入验证码" bindinput="onInput" data-key="code" style="flex: 1;" />
        <button class="code-btn" bindtap="getCode" disabled="{{countdown > 0}}">
          {{countdown > 0 ? countdown + 's后重发' : '获取验证码'}}
        </button>
      </view>
      <button class="next-btn" bindtap="nextStep">下一步</button>
    </view>
    
    <!-- 步骤2：设置新密码 -->
    <view wx:if="{{step == 2}}">
      <view class="form-item">
        <input class="input" placeholder="请设置6-20位新密码" bindinput="onInput" data-key="password" password />
      </view>
      <view class="form-item">
        <input class="input" placeholder="请确认新密码" bindinput="onInput" data-key="confirmPassword" password />
      </view>
      <button class="next-btn" bindtap="confirmReset">确定</button>
    </view>
    
    <!-- 步骤3：重置成功 -->
    <view wx:if="{{step == 3}}" class="success">
      <view class="success-icon">✓</view>
      <view class="success-text">密码重置成功</view>
      <view class="success-subtext">16分钟后密码将自动恢复</view>
      <button class="login-btn" bindtap="goToLogin">进入登录</button>
    </view>
  </view>
</view>
