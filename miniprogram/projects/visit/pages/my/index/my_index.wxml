<view class="main {{skin.IS_SUB?'sub-margin-bottom':''}}">
	<!--top area begin-->
	<view class="upside upside-shadow" bindtap="url" data-url="{{user?'../edit/my_edit':'../reg/my_reg'}}">
		<image mode="widthFix" lazy-load class="upImg loading" src="../../../images/my.jpg" />
		<view class="user-bar">
			<view class="avatar">
				<image mode="aspectFit" src="../../../images/tabbar/my_cur.png" />
			</view>
			<view class="detail">
				<view class="name text-cut">{{user?user.fullName:'-'}}</view>
				<view class="desc">
					<view class="text-cut">单位：{{user.organizationName}}</view>
				</view>
			</view>
		</view>
	</view>
	<!--top area end-->

	<!--down area begin-->
	<view class="down padding-project">

		<view class="repair card-project shadow-project">
			<view class="title" bindtap="url" data-url="../../task/my_list/task_my_list">我的审批
				<text bindtap="url" data-type="relaunch" data-url="../../task/my_list/task_my_list" class="right">全部<text class="icon-right" /></text>
			</view>
			<view class="item-list">
				<view class="item" bindtap="url" data-type="relaunch" data-url="../../task/my_list/task_my_list?status=0">
					<view wx:if="{{task&&task.status0Cnt}}" class="num">{{task.status0Cnt}}</view>
					<image src="../../../images/my/task_0.png" />
					<text>待审批</text>
				</view>
				<view class="item" bindtap="url" data-type="relaunch" data-url="../../task/my_list/task_my_list?status=1">
					<view wx:if="{{task&&task.status1Cnt}}" class="num">{{task.status1Cnt}}</view>
					<image src="../../../images/my/task_1.png" />
					<text>已审批</text>
				</view>
				<view class="item" bindtap="url" data-type="relaunch" data-url="../../task/my_list/task_my_list?status=2">
					<view wx:if="{{task&&task.status2Cnt}}" class="num">{{task.status2Cnt}}</view>
					<image src="../../../images/my/task_2.png" />
					<text>审批未过</text>
				</view>
			</view>
		</view>

		<!--base begin -->
		<view class="comm-list menu card-project shadow-project">
			<view wx:if="{{user&&user.USER_STATUS!=9}}" class="item arrow" bindtap="url" data-url="../edit/my_edit">
				<view class="content">
					<text class="icon-edit my-icon-project text-green"></text>
					<text class="text-black">修改我的资料</text>
				</view>
			</view>

			<view wx:if="{{!skin.IS_SUB}}" class="item arrow" bindtap="bindSetTap">
				<view class="content">
					<text class="icon-settings my-icon-project text-grey"></text>
					<text class="text-black">设置</text>
				</view>
			</view>

		</view>
		<!--sys end -->

	</view>
	<!--down area end-->

</view>
<view style="height:100rpx"></view>



<block wx:if="{{skin.IS_SUB}}">
	<import src="../../tpls/menu_tpl.wxml" />
	<template is="menuTpl" data="{{curMenu:'my_index',returnHome:false}}" />
</block>