<block wx:if="{{isLogin&&isLoad}}">
	<cmpt-comm-list pulldownType="{{['modal','modal']}}" type="my-task-list" search="{{search}}" _menus="{{sortMenus}}" _items="{{sortItems}}" route="task/my_list" isTotalMenu="{{true}}" sortMenusDefaultIndex="{{sortMenusDefaultIndex}}" topBottom="120" placeholder="搜索项目名称/标段" bind:list="bindCommListCmpt">

		<view slot="searchEnd">

		</view>

		<!-- List Begin -->
		<view class="text-pic-list-box padding-project">
			<view class="item card-project shadow-project" wx:for="{{dataList.list}}" wx:key="index">
				<view class="status-right-top bg-orange">{{item.processName}}</view>
				<view class="title"><image src="../../../images/check.png" />{{item.TASK_OBJ.dept}} <text class="tag small radius margin-left-xs" style="background-color: {{item.approvalStatusBg}} !important">{{item.approvalStatusName}}</text></view>
        <view class="author">
					<view class="txt">项目名称：</view>
					<view class="info">{{item.title}}</view>
        </view>
        <view class="author">
					<view class="txt">标段：</view>
					<view class="info">{{item.sectionName}}</view>
				</view>
				<view class="author">
					<view class="txt">申请人：</view>
					<view class="info">{{item.applicantUserName}}</view>
				</view> 
				<view class="author">
					<view class="txt">审批人：</view>
					<view class="info">{{item.TASK_OBJ.desc}}</view>
        </view> 
        <view class="author">
					<view class="txt">审批时间：</view>
					<view class="info">{{item.applyTime}}</view>
				</view>

				<view class="data data-button" wx:if="{{isEdit}}">
					<button wx:if="{{item.TASK_STATUS!=0}}" bindtap="url" data-url="../edit/task_edit?cateId={{cateId}}&id={{item._id}}" class="btn mid bg-gray text-black">查看详情</button>
					<button wx:else bindtap="url" data-url="../edit/task_edit?cateId={{cateId}}&id={{item._id}}" class="btn mid bg-gray text-black">详情/修改</button>
				</view>

			</view>

			<!--load begin-->
			<import src="../../../../../tpls/public/list_load_tpl.wxml" />
			<template is="listLoadTpl" data="{{skin:'load-project',dataList}}" />
			<!--load end-->

		</view>
		<!-- List END -->

	</cmpt-comm-list>


 

	<block wx:if="{{skin.IS_SUB}}">
		<import src="../../tpls/menu_tpl.wxml" />
		<template is="menuTpl" data="{{curMenu:'my_task',returnHome:false}}" />
	</block>

</block>