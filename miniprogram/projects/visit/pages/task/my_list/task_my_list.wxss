@import "../../../../../style/public/article_list.wxss";
@import "../../../style/skin.wxss";

/* 页面容器 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 原生 Tab 样式 */
.tab-container {
  display: flex;
  background-color: white;
  border-radius: 10rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 15rpx 0;
  border-radius: 8rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background-color: #0055BE;
  color: white;
}

.tab-item text {
  font-size: 28rpx;
  font-weight: 500;
}

/* 搜索栏样式 */
.search-bar {
  display: flex;
  margin-bottom: 20rpx;
  background-color: white;
  border-radius: 10rpx;
  padding: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.search-input {
  flex: 1;
  height: 60rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
}

.search-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: #0055BE;
  color: white;
  font-size: 28rpx;
  border-radius: 10rpx;
  margin-left: 10rpx;
}

/* 滚动区域 */
.list-scroll {
  width: 100%;
  box-sizing: border-box;
}

.text-pic-list-box .item {
	padding: 10rpx 0rpx 20rpx;
	position: relative;
	overflow: hidden;
}


.btn.mid {
	padding: 0 30rpx;
}

.text-pic-list-box .item {
	overflow: hidden;
}

.text-pic-list-box .item .author {
	font-size: 24rpx;
	color: #666;
	padding: 0 30rpx;
	display: flex;
	align-items: baseline !important;
}

.text-pic-list-box .item .author .txt {
	width: 120rpx; 
	text-align-last: justify;
	margin-right: 10rpx;
	color: #999;
}


.text-pic-list-box .item .author .info {
	flex: 1;
}

.text-pic-list-box .item .title {
	width: 100%;
	position: relative;
	padding-right: 20rpx;
	border-bottom: 1rpx solid #eee;
	padding-bottom: 20rpx;
	padding: 10rpx 30rpx 20rpx 30rpx;
	font-size: 28rpx;
	max-height: 120rpx;
	display: flex;
  align-items: center;
  color: #fff;
}

.text-pic-list-box .item image {
	width: 30rpx;
	height: 30rpx;
	margin-right: 10rpx;
}

.text-pic-list-box .item .data {
	line-height: 1.5;
	font-size: 26rpx;
	color: #666;
	margin-top: 10rpx;
	display: flex;
	justify-content: flex-start;
	align-items: center;
	padding: 0 30rpx;
}

.text-time {
	color: #ccc;
}

.text-pic-list-box .item .data.data-button {
	margin-top: 25rpx;
}