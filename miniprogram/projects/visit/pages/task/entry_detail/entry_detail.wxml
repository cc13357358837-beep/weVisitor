<block wx:if="{{isLoad}}">
	<view class="main padding-project">
		<!-- 审核页面 -->
		<view style="width: 100%;">
			<view class="card-project shadow-project margin-bottom">
        <text class="form-item" style="font-weight: bold;isplay: flex;justify-content: center;">基本信息</text>
				<view class="form-item">
					<view class="label">流水号</view>
					<view class="value">{{task.serialNumber || '暂无'}}</view>
				</view>
				<view class="form-item">
					<view class="label">设备名称</view>
					<view class="value">{{task.name || '暂无'}}</view>
				</view>
				<view class="form-item">
					<view class="label">申请开始使用时间</view>
					<view class="value">{{task.plannedUseStartTime || '暂无'}}</view>
				</view>
				<view class="form-item">
					<view class="label">申请结束使用时间</view>
					<view class="value">{{task.plannedUseEndTime || '暂无'}}</view>
				</view>
				<view class="form-item">
					<view class="label">申请时间</view>
					<view class="value">{{task.applicationTime || '暂无'}}</view>
				</view>
			</view>

			<!-- 已审核状态显示 -->
      
			<view class="card-project shadow-project margin-bottom" wx:if="{{task.approvalStatusId !== null && task.approvalStatusId !== undefined}}">
        <text class="form-item" style="font-weight: bold;display: flex;justify-content: center;">审批流程</text>
        <text class="form-item" style="font-weight: bold;">进场申请</text>
				<view class="form-item">
					<view class="label">申请人</view>
					<view class="value">{{task.constructionApplicantUserName || '暂无'}}</view>
				</view>
        <view class="form-item">
					<view class="label">申请时间</view>
					<view class="value">{{task.applicationTime || '暂无'}}</view>
				</view>
        <view class="form-item">
					<view class="label">进场时间</view>
					<view class="value">{{task.plannedUseStartTime || '暂无'}}</view>
				</view>
        <text class="form-item" style="font-weight: bold;">租赁单位审核</text>
        <view class="form-item">
					<view class="label">审核人</view>
					<view class="value">{{task.constructionManagerUserId || '暂无'}}</view>
				</view>
				 <view class="form-item">
					<view class="label">审核状态</view>
					<view class="value">{{task.applicantApprovalStatusName || '暂无'}}</view>
				</view>
        <view class="form-item">
					<view class="label">审核意见</view>
					<view class="value">{{task.applicantReviewComment || '暂无'}}</view>
				</view>
        <view class="form-item">
					<view class="label">租赁单位审核时间</view>
					<view class="value">{{task.applicantReviewTime || '暂无'}}</view>
				</view>
        <text class="form-item" style="font-weight: bold;">施工单位</text>
        <view class="form-item">
					<view class="label">审核人</view>
					<view class="value">{{task.constructionManagerUserName || '暂无'}}</view>
				</view>
        <view class="form-item">
					<view class="label">审核状态</view>
					<view class="value">{{task.constructionManagerApprovalStatusName || '暂无'}}</view>
				</view>
        <view class="form-item">
					<view class="label">审核意见</view>
					<view class="value">{{task.constructionManagerReviewComment || '暂无'}}</view>
				</view>
        <view class="form-item">
					<view class="label">审核时间</view>
					<view class="value">{{task.constructionManagerReviewTime || '暂无'}}</view>
				</view>
        <text class="form-item" style="font-weight: bold;">监理单位</text>
        <view class="form-item">
					<view class="label">审核人</view>
					<view class="value">{{task.rentalManagerUserName || '暂无'}}</view>
				</view>
        <view class="form-item">
					<view class="label">审核状态</view>
					<view class="value">{{task.rentalManagerApprovalStatusName || '暂无'}}</view>
				</view>
        
        <view class="form-item">
					<view class="label">审核意见</view>
					<view class="value">{{task.rentalManagerReviewComment || '暂无'}}</view>
				</view>
        <view class="form-item">
					<view class="label">施工单位审核时间</view>
					<view class="value">{{task.rentalManagerReviewTime || '暂无'}}</view>
				</view>
			</view>

			<!-- 待审核时显示审核按钮 -->
			<block wx:if="{{task.approvalStatusId === null || task.approvalStatusId === undefined}}">
				<view class="card-project shadow-project margin-bottom">
					<view class="form-item">
						<view class="label">审核理由</view>
						<view class="value">
							<textarea placeholder="请输入审核理由（驳回时必填）" value="{{approvalReason}}" bindinput="bindApprovalReasonInput" style="width: 100%; height: 150rpx; border: 1rpx solid #e8e8e8; border-radius: 8rpx; padding: 16rpx;"></textarea>
						</view>
					</view>
				</view>

				<view class="button-group" style="display: flex; gap: 20rpx;">
					<button bindtap="reject" class="btn-base btn-project shadow" style="flex: 1; background-color: #ff4d4f;">驳回</button>
					<button bindtap="approve" class="btn-base btn-project shadow" style="flex: 1; background-color: #52c41a;">同意</button>
				</view>
			</block>
		</view>
	</view>
</block>

<block wx:if="{{!isLoad}}">
	<view class="loading-text">加载中...</view>
</block>