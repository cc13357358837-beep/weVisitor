<block>
	<view class="main padding-project">
		<!-- 审核页面 -->
		<view style="width: 100%;">
			<view class="card-project shadow-project margin-bottom">
				<view class="form-item">
					<view class="label">流水号</view>
					<view class="value">{{task.TASK_OBJ.serialNumber || '暂无'}}</view>
				</view>
				<view class="form-item">
					<view class="label">设备名称</view>
					<view class="value">{{task.TASK_OBJ.name || '暂无'}}</view>
				</view>
				<view class="form-item">
					<view class="label">型号</view>
					<view class="value">{{task.TASK_OBJ.model || '暂无'}}</view>
				</view>
				<view class="form-item">
					<view class="label">牌照</view>
					<view class="value">{{task.TASK_OBJ.licensePlate || '暂无'}}</view>
				</view>
				<view class="form-item">
					<view class="label">租赁单位</view>
					<view class="value">{{task.TASK_OBJ.rentalUnit || '暂无'}}</view>
				</view>
				<view class="form-item">
					<view class="label">申请时间</view>
					<view class="value">{{task.TASK_OBJ.applyTime || '暂无'}}</view>
				</view>
			</view>

			<view class="card-project shadow-project margin-bottom">
				<view class="form-item">
					<view class="label">审核结果</view>
					<view class="value radio-group">
						<radio-group bindchange="bindApprovalResultChange">
							<label class="radio-label">
								<radio value="1" checked="{{approvalResult === '1'}}"/>通过
							</label>
							<label class="radio-label">
								<radio value="0" checked="{{approvalResult === '0'}}"/>不通过
							</label>
						</radio-group>
					</view>
				</view>
				<view class="form-item">
					<view class="label">审核理由</view>
					<view class="value">
						<textarea placeholder="请输入审核理由" value="{{approvalReason}}" bindinput="bindApprovalReasonInput" style="width: 100%; height: 150rpx; border: 1rpx solid #e8e8e8; border-radius: 8rpx; padding: 16rpx;"></textarea>
					</view>
				</view>
			</view>

			<view class="button-group">
				<button bindtap="submitApproval" class="btn-base btn-project shadow margin-right">提交审核</button>
			</view>
		</view>
	</view>

</block>