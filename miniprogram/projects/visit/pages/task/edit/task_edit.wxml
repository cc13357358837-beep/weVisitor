<block wx:if="{{isLoad}}">
	<view class="main padding-project">
		<!-- 审核页面 -->
		<view style="width: 100%;">
			<view class="card-project shadow-project margin-bottom">
				<view class="form-item">
					<view class="label">流水号</view>
					<view class="value">{{task.serialNumber || '暂无'}}</view>
				</view>
				<view class="form-item">
					<view class="label">设备名称</view>
					<view class="value">{{task.name || '暂无'}}</view>
				</view>
				<view class="form-item">
					<view class="label">型号</view>
					<view class="value">{{task.model || '暂无'}}</view>
				</view>
				<view class="form-item">
					<view class="label">牌照</view>
					<view class="value">{{task.licensePlate || '暂无'}}</view>
				</view>
				<view class="form-item">
					<view class="label">租赁单位</view>
					<view class="value">{{task.rentalOrganizationName || '暂无'}}</view>
				</view>
				<view class="form-item">
					<view class="label">申请时间</view>
					<view class="value">{{task.latestUpdateTime || '暂无'}}</view>
				</view>
			</view>

			<!-- 已审核状态显示 -->
			<view class="card-project shadow-project margin-bottom" wx:if="{{!task.showApproveButton}}">
				<view class="form-item">
					<view class="label">审批状态</view>
					<view class="value" style="color: {{task.approvalStatusId === 1 ? '#ff4d4f' : '#52c41a'}}">{{task.approvalStatusName || '暂无'}}</view>
				</view>
				<view class="form-item">
					<view class="label">审核理由</view>
					<view class="value">{{task.approvalReason||'-'}}</view>
				</view>
        <view class="form-item">
					<view class="label">审核时间</view>
					<view class="value">{{task.approvalTime}}</view>
				</view>
			</view>

			<!-- 待审核时显示审核按钮 -->
			<block wx:if="{{task.showApproveButton}}">
				<view class="card-project shadow-project margin-bottom">
					<view class="form-item">
						<view class="label">审核理由</view>
						<view class="value">
							<textarea placeholder="请输入审核理由（驳回时必填）" value="{{approvalReason}}" bindinput="bindApprovalReasonInput" style="width: 100%; height: 150rpx; border: 1rpx solid #e8e8e8; border-radius: 8rpx; padding: 16rpx;"></textarea>
						</view>
					</view>
				</view>

				<view class="button-group" style="display: flex; gap: 20rpx;">
					<button bindtap="reject" class="btn-base btn-project shadow" style="flex: 1; background-color: #ff4d4f;">驳回</button>
					<button bindtap="approve" class="btn-base btn-project shadow" style="flex: 1; background-color: #52c41a;">同意</button>
				</view>
			</block>
		</view>
	</view>
</block>

<block wx:if="{{!isLoad}}">
	<view class="loading-text">加载中...</view>
</block>