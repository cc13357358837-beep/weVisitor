.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.search-bar {
  display: flex;
  margin-bottom: 20rpx;
  background-color: white;
  border-radius: 10rpx;
  padding: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.search-input {
  flex: 1;
  height: 60rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
}

.search-btn {
  width: 120rpx;
  height: 60rpx;
  background-color: #0055BE;
  color: white;
  font-size: 28rpx;
  border-radius: 10rpx;
  margin-left: 10rpx;
}

.equipment-list {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.equipment-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.equipment-item:last-child {
  border-bottom: none;
}

.equipment-info {
  flex: 1;
  margin-right: 20rpx;
}

.equipment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.equipment-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
}

.status-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: white;
}

.equipment-status {
  font-size: 26rpx;
  color: #666;
}

.arrow-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  /* width: 40rpx; */
  height: 40rpx;
}

.arrow {
  font-size: 40rpx;
  color: #999;
  font-weight: 400;
  margin-left: 10rpx;
}

.loading {
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #999;
}
