<view class="container">
  <view class="search-bar">
    <input class="search-input" placeholder="请输入设备名称" bindinput="onSearchInput" />
    <button class="search-btn" bindtap="search">搜索</button>
  </view>
  
  <view class="equipment-list">
    <view wx:for="{{equipmentList}}" wx:key="id" class="equipment-item" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="equipment-info">
        <view class="equipment-header">
          <text class="equipment-name">{{item.name}}</text>
        </view>
        <text class="equipment-status">{{item.statusName || ''}}</text>
      </view>
      <view class="arrow-icon">
        <view class="status-badge" style="background-color: {{item.statusBg}}">{{item.statusName || ''}}</view>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>
  
  <view wx:if="{{isLoading}}" class="loading">
    <text>加载中...</text>
  </view>
  
  <view wx:if="{{!isLoading && equipmentList.length === 0}}" class="empty">
    <text>暂无设备数据</text>
  </view>
</view>
