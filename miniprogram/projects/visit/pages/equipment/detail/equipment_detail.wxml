<view class="container">
  <view class="equipment-header" wx:if="{{equipmentData}}" style="background: linear-gradient(135deg, {{statusBg}} 0%, {{statusBg}}dd 100%);">
    <view class="equipment-title">
      <text class="title-text">{{equipmentData.name}}</text>
      <view class="status-badge">{{equipmentData.statusName || ''}}</view>
    </view>
  </view>
  
  <view class="equipment-info" wx:if="{{equipmentData}}">
    <view style="font-weight: 600;">基本信息</view>
    <view class="info-item">
      <text class="label">型号</text>
      <text class="value">{{equipmentData.serialNumber || '-'}}</text>
    </view>
    <view class="info-item">
      <text class="label">牌照</text>
      <text class="value">{{equipmentData.licensePlate || '-'}}</text>
    </view>
    <view class="info-item">
      <text class="label">出厂编号</text>
      <text class="value">{{equipmentData.factorySerialNumber || '-'}}</text>
    </view>
    <view class="info-item">
      <text class="label">设备类型</text>
      <text class="value">{{equipmentData.equipmentTypeName || '-'}}</text>
    </view>
    <view class="info-item">
      <text class="label">标段</text>
      <text class="value">{{equipmentData.sectionName || '-'}}</text>
    </view>
    <view class="info-item">
      <text class="label">租赁单位</text>
      <text class="value">{{equipmentData.rentalOrganizationName || '-'}}</text>
    </view>
    <view class="info-item">
      <text class="label">设备来源</text>
      <text class="value">{{equipmentData.equipmentSourceName || '-'}}</text>
    </view>
  </view>
  <view  class="equipment-info" wx:if="{{equipmentData}}">
    <view style="font-weight: 600;">流程信息</view>
    <view class="info-item">
      <text class="label">审核人员</text>
      <text class="value">{{equipmentData.constructionReviewerUserName || '-'}}</text>
    </view>
    <view class="info-item">
      <text class="label">审核状态</text>
      <text class="value" style="color: {{equipmentData.approvalStatusId === 1 ? '#ff4d4f' : equipmentData.approvalStatusId === 2?'#52c41a':'#1890ff'}}">{{equipmentData.approvalStatusName || '待审核'}}</text>
    </view>
    <view class="info-item" wx:if="{{equipmentData.approvalStatusId===1}}">
      <text class="label">审核原因</text>
      <text class="value">{{equipmentData.approvalReason || '-'}}</text>
    </view>
    <view class="info-item" wx:if="{{equipmentData.approvalStatusId}}">
      <text class="label">审核时间</text>
      <text class="value">{{equipmentData.applicationTime || '-'}}</text>
    </view>
  </view>
  
  <view wx:if="{{isLoading}}" class="loading">
    <text>加载中...</text>
  </view>
  
  <view wx:if="{{!isLoading && !equipmentData}}" class="empty">
    <text>暂无设备数据</text>
  </view>

  <!-- 审批按钮 -->
  <view wx:if="{{equipmentData && equipmentData.showApproveButton}}" class="button-group">
    <button class="btn-submit" bindtap="approve">同意</button>
    <button class="btn-reject" bindtap="reject">驳回</button>
  </view>
</view>