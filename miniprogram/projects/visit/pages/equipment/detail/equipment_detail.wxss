.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.equipment-header {
  background-color: #52c41a;
  color: white;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.equipment-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title-text {
  font-size: 36rpx;
  font-weight: bold;
  flex: 1;
  margin-right: 20rpx;
}

.status-badge {
  background-color: rgba(255, 255, 255, 0.3);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.equipment-info {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  align-items: center;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
  flex: 1;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 2;
  text-align: right;
}

.project-item {
  cursor: pointer;
}

.project-value {
  display: flex;
  align-items: center;
  flex: 2;
  justify-content: flex-end;
}

.arrow {
  font-size: 32rpx;
  color: #999;
  font-weight: bold;
  margin-left: 10rpx;
}

.loading {
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #999;
}

.button-group {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.btn-submit {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #1890ff;
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

.btn-reject {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #fff;
  color: #ff4d4f;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: 2rpx solid #ff4d4f;
}
