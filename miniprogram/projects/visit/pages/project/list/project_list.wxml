<view class="container">
  <view class="search-bar">
    <input class="search-input" placeholder="请输入项目名称" bindinput="onSearchInput" />
    <button class="search-btn" bindtap="search">搜索</button>
  </view>
  
  <view class="project-list">
    <view wx:for="{{projectList}}" wx:key="id" class="project-item">
      <view class="project-header">
        <text class="project-name">{{item.name}}</text>
        <!-- <text class="project-code">{{item.code}}</text> -->
      </view>
      <view class="project-info">
        <text class="info-item">施工单位: {{item.headquartersOrganization||'-'}}</text>
        <text class="info-item">建设地点: {{item.constructionLocation}}</text>
      </view>
    </view>
  </view>
  
  <view wx:if="{{isLoading}}" class="loading">
    <text>加载中...</text>
  </view>
  
  <view wx:if="{{!isLoading && projectList.length === 0}}" class="empty">
    <text>暂无项目数据</text>
  </view>
</view>
