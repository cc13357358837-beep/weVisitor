.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.search-bar {
  display: flex;
  margin-bottom: 20rpx;
  background-color: white;
  border-radius: 10rpx;
  padding: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.search-input {
  flex: 1;
  height: 60rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
}

.search-btn {
  width: 120rpx;
  height: 60rpx;
  background-color: #0055BE;
  color: white;
  font-size: 28rpx;
  border-radius: 10rpx;
  margin-left: 10rpx;
}

.project-list {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.project-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
}

.project-item:last-child {
  border-bottom: none;
}

.project-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.project-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.project-code {
  font-size: 24rpx;
  color: #999;
}

.project-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.info-item {
  font-size: 26rpx;
  color: #666;
}

.loading {
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #999;
}
