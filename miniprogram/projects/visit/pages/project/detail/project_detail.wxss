.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.project-header {
  background-color: #0055BE;
  color: white;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.project-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title-text {
  font-size: 36rpx;
  font-weight: bold;
  flex: 1;
  margin-right: 20rpx;
}

.status-badge {
  background-color: rgba(255, 255, 255, 0.3);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.project-info {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
  flex: 1;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 2;
  text-align: right;
}

.equipment-section {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 20rpx 0rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.equipment-count {
  font-size: 24rpx;
  color: #999;
}
.arrow {
  font-size: 30rpx;
  color: #999;
  font-weight: 400;
  margin-left: 10rpx;
}

.acceptance-section {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.acceptance-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.loading {
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #999;
}
