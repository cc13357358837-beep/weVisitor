<view class="main">
	<view class="top">
	</view>

	<view class="box">
		<view class="inner">

			<view class="item" bindtap="url" data-type="relaunch" data-url="/projects/visit/pages/project/list/project_list">
				<view class="left">
					<image mode="aspectFill" src="../../../images/home/add.png" />
				</view> 
				<view class="right">
					<view class="title">项目查询</view>
					<view class="desc">查询项目实时分布</view>
				</view>
			</view>

			<view class="item" bindtap="url" data-type="relaunch" data-url="../../task/my_list/task_my_list">
